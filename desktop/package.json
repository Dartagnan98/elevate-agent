{
  "name": "@elevationrealestate/elevate-desktop",
  "version": "0.15.0",
  "description": "Elevate desktop app shell.",
  "private": true,
  "main": "src/main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack:mac": "electron-builder --mac dir",
    "build:mac": "electron-builder --mac dmg zip --x64 --arm64",
    "release:mac": "electron-builder --mac dmg zip --x64 --arm64 --publish never && node scripts/ship-to-hetzner.js"
  },
  "build": {
    "appId": "com.elevationrealestate.elevate",
    "productName": "Elevate",
    "artifactName": "Elevate-${version}-${os}-${arch}.${ext}",
    "protocols": [
      {
        "name": "Elevate",
        "schemes": [
          "elevate"
        ]
      }
    ],
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime/${arch}/python",
        "to": "runtime/python",
        "filter": ["**/*"]
      },
      {
        "from": "../cli",
        "to": "cli",
        "filter": [
          "**/*",
          "!web/**",
          "!ui-tui/**",
          "!venv/**",
          "!.venv/**",
          "!tests/**",
          "!docs/**",
          "!docker/**",
          "!nix/**",
          "!plans/**",
          "!website/**",
          "!packaging/**",
          "!datagen-config-examples/**",
          "!temp_vision_images/**",
          "!scripts/**",
          "!assets/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!.git/**",
          "!.pytest_cache/**",
          "!**/.DS_Store",
          "!*.egg-info/**"
        ]
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://api.elevationrealestatehq.com/updates",
        "channel": "latest"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Elevate uses the microphone for voice input in chat."
      },
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Elevate"
    }
  },
  "devDependencies": {
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  }
}
