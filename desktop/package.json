{
  "name": "@elevationrealestate/elevate-desktop",
  "version": "1.2.60",
  "description": "Elevate desktop app shell.",
  "private": true,
  "main": "src/main.js",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "electron .",
    "build:web": "npm --prefix ../cli/web run build",
    "pack:mac": "npm run build:web && electron-builder --mac dir",
    "build:mac": "npm run build:web && export APPLE_KEYCHAIN_PROFILE=${APPLE_KEYCHAIN_PROFILE:-elevate-notarization}; electron-builder --mac dmg zip --x64 --publish never && electron-builder --mac dmg zip --arm64 --publish never && npm run merge:mac-feed",
    "preflight:apple": "node scripts/preflight-apple-release.js",
    "merge:mac-feed": "node scripts/merge-mac-feed.js",
    "finalize:mac": "node scripts/finalize-mac-dist.js",
    "smoke:mac": "VERSION=$(node -p \"require('./package.json').version\") && ../cli/.venv/bin/python ../cli/scripts/installed_runtime_smoke.py --installed-app dist/mac/Elevate.app --expected-app-version \"$VERSION\" --skip-sidecar && ../cli/.venv/bin/python ../cli/scripts/installed_runtime_smoke.py --installed-app dist/mac-arm64/Elevate.app --expected-app-version \"$VERSION\" --skip-sidecar",
    "ship:mac": "node scripts/ship-to-hetzner.js",
    "release:mac": "npm run build:mac && npm run finalize:mac && npm run smoke:mac && npm run ship:mac",
    "release:apple": "npm run preflight:apple && npm run release:mac"
  },
  "build": {
    "appId": "com.elevationrealestate.elevate",
    "productName": "Elevate",
    "artifactName": "Elevate-${version}-${os}-${arch}.${ext}",
    "protocols": [
      {
        "name": "Elevate",
        "schemes": [
          "elevate"
        ]
      }
    ],
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime/${arch}/python",
        "to": "runtime/python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/.DS_Store"
        ]
      },
      {
        "from": "../cli",
        "to": "cli",
        "filter": [
          "**/*",
          "!web/**",
          "!ui-tui/**",
          "!venv/**",
          "!.venv/**",
          "!tests/**",
          "!docs/**",
          "!docker/**",
          "!nix/**",
          "!plans/**",
          "!website/**",
          "!packaging/**",
          "!datagen-config-examples/**",
          "!temp_vision_images/**",
          "!scripts/**",
          "!assets/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!.git/**",
          "!.pytest_cache/**",
          "!**/.DS_Store",
          "!*.egg-info/**",
          "!**/*.db",
          "!**/*.db-shm",
          "!**/*.db-wal",
          "!**/*.sqlite",
          "!**/*.sqlite3"
        ]
      },
      {
        "from": "../cli/scripts/whatsapp-bridge",
        "to": "cli/scripts/whatsapp-bridge",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!node_modules",
          "!**/.DS_Store"
        ]
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://api.elevationrealestatehq.com/updates",
        "channel": "latest"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "LSMinimumSystemVersion": "12.0",
        "NSMicrophoneUsageDescription": "Elevate uses the microphone for voice input in chat.",
        "NSAppleEventsUsageDescription": "Elevate sends approved text messages through the Messages app on your Mac.",
        "NSHumanReadableCopyright": "(c) 2026 Elevation Real Estate. All rights reserved."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Elevate"
    }
  },
  "devDependencies": {
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "js-yaml": "^4.1.1"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  },
  "overrides": {
    "tmp": "^0.2.7"
  }
}
