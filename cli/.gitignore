# But the central data module's source code IS tracked. The blanket `data/`
# rule above exists to ignore on-disk runtime data dirs (e.g. ~/.elevate/data
# bind-mounts, scratch dirs left by tests). The Python package and its
# tests are part of the codebase.
!elevate_cli/data/
!elevate_cli/data/**
!tests/elevate_cli/data/
!tests/elevate_cli/data/**
.pytest_cache/
tmp/
temp_vision_images/
hermes-*/*
examples/
tests/quick_test_dataset.jsonl
tests/sample_dataset.jsonl
