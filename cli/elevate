#!/usr/bin/env python3
"""Elevate CLI launcher.

This wrapper should behave like the installed `elevate` command, including
subcommands such as `gateway`, `cron`, and `doctor`.
"""

from pathlib import Path
import os
import sys


if __name__ == "__main__":
    root = Path(__file__).resolve().parent
    for env_dir in (".venv", "venv"):
        python = root / env_dir / "bin" / "python"
        if python.exists():
            try:
                already_running = Path(sys.executable).resolve().samefile(python)
            except OSError:
                already_running = Path(sys.executable).resolve() == python.resolve()
            if already_running:
                break
            os.execv(str(python), [str(python), "-m", "elevate_cli.main", *sys.argv[1:]])

    from elevate_cli.main import main

    exit_code = main()
    if exit_code:
        sys.exit(exit_code)
