# Elevation HQ local store. File-backed by default; no hosted database required.
ELEVATE_HQ_STORE_PATH=.data/elevation-hq-store.json
ELEVATE_HQ_DEV_EMAIL=dev@elevationrealestatehq.com
ELEVATE_HQ_DEV_PASSWORD=elevate-dev
ELEVATE_HQ_DEV_ENTITLEMENTS=real_estate_sales,real_estate_marketing,real_estate_admin,real_estate_cma
# Optional: comma-separated skill roots. Use entitlement=/abs/path to override.
# Defaults seed real-estate admin, sales, and marketing skills from cli/skills.
ELEVATE_HQ_SKILL_SEED_DIRS=

# JWT signing — generate a 32-byte random secret (openssl rand -base64 32)
JWT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — pricing
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_BUILDER_MONTHLY=price_xxx
