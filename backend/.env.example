# Supabase (service key — server only, never expose to browser)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=

# JWT signing — generate a 32-byte random secret (openssl rand -base64 32)
JWT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — pricing
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_BUILDER_MONTHLY=price_xxx
